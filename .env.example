# Copy this file to .env and fill in your own values before running the app.

# Generate one with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Generate the hash by running this once (replace 'your-password-here' with your actual password):
# python3 -c "from werkzeug.security import generate_password_hash; print(generate_password_hash('your-password-here', method='pbkdf2:sha256'))"
# Then paste the output here.
ADMIN_PASSWORD_HASH=
